import Foundation

let restaurantName = "Swift Sliceria"
let welcomeMessage = "Welcome to S. Sliceria, the best byte in the city, check out our menu below!"

let menuItems = [
    "Swift @State Salad",
    "Array Alfredo",
    "Conditional Combo"
]

let ingredients = [
    "flour, gluten, butter",
    "peanut, garlic, olive oil",
    "rice, tomato, basil"
]

print(" == \(restaurantName) == ")
print(welcomeMessage)
print("")

for (index, item) in menuItems.enumerated() {
    print("\(index + 1). \(item)")

    let recipeIndex = index

    let recipe = ingredients[recipeIndex].components(separatedBy: ", ")

    for ingredient in recipe {
        print("\(ingredient) ")
    }
}

let allergens = ["peanut", "gluten"]

func printAllergens() {
    for allergen in allergens {
        print(allergen)
    }
}

func checkIngredients(_ ingredients: [String]) -> Bool {
    for ingredient in ingredients {
        if allergens.contains(ingredient) {
            return true
        }
    }
    return false
}

print("--- Allergen List ---")
printAllergens()

print("@State Salad safe?", !checkIngredients(ingredients[0].components(separatedBy: ", ")))
print("Array Alfredo safe?", !checkIngredients(ingredients[1].components(separatedBy: ", ")))
print("Conditional Combo safe?", !checkIngredients(ingredients[2].components(separatedBy: ", ")))

print("Has allergen?", checkIngredients(["salt", "pepper"]))
print("Has allergen?", checkIngredients(["sugar", "peanut"]))
